CREATE PROCEDURE SP_L_PRODUCTO_03
@PROD_ID INT
AS  
BEGIN  
 SELECT   
  TMCATEGORIA.CAT_NOM,   
  TM_PRODUCTO.PROD_NOM,   
  TM_PRODUCTO.PROD_ID,   
  TM_PRODUCTO.CAT_ID  
 FROM       
  TM_PRODUCTO INNER JOIN  
  TMCATEGORIA ON TM_PRODUCTO.CAT_ID = TMCATEGORIA.CAT_ID
WHERE
	TM_PRODUCTO.PROD_ID = @PROD_ID
END

EXEC SP_L_PRODUCTO_03 2
